# ══════════════════════════════════════════════════════════════
# PRISM Analyst Services — Environment Variables
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Provider-agnostic: works with Neon (recommended for dev/staging), AWS RDS,
# Supabase, Railway, or any PostgreSQL instance.
# ══════════════════════════════════════════════════════════════

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=true                          # set to false in prod
CORS_ORIGINS=["http://localhost:3000"]
API_PREFIX=/api/v1

# ── Database ──
# Easiest: one URL. Neon and most managed Postgres providers give you this.
#
#   Neon (recommended — free tier, pgvector pre-installed):
#     DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/prism?sslmode=require
#     DB_SSL_MODE=require
#
#   AWS RDS Mumbai:
#     DATABASE_URL=postgresql://user:pass@your-instance.ap-south-1.rds.amazonaws.com/prism
#     DB_SSL_MODE=verify-ca
#
#   Local Docker:
#     DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prism
#     DB_SSL_MODE=disable
#
# Replace with YOUR connection string — never commit a real one here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.aws.neon.tech/DBNAME?sslmode=require
DB_SSL_MODE=prefer

# Optional fine-grained controls (have sane defaults):
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_PRE_PING=true
# DB_ECHO=false

# ── Tests ──
# Pytest reads TEST_DATABASE_URL; CI provides this automatically.
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prism_test

# ── LLM Keys (Gemini AI Studio — free tier) ──
# Get one in 1 minute at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM / 1M tokens/day per key per model — see screenshots
# of the API key dashboard for exact RPM/TPM/RPD per model.
#
# Adding multiple keys is STRONGLY recommended. ModelRouter treats each
# (model × key) pair as an independent deployment and load-balances across
# them, doubling/tripling effective free-tier capacity. All five slots are
# read by ``settings.gemini_api_keys`` at startup; empty slots are skipped.
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# Optional fallback provider (paid) — not used in free-tier flow.
# OPENROUTER_API_KEY=

# ── Google ADK / Agent runtime ──
# "ai_studio" uses the GEMINI_API_KEY* set above. Switch to "vertex" + a GCP
# project when data residency / IAM / billing-on-invoice matter (Phase 4+).
ADK_PROVIDER=ai_studio
# ADK_VERTEX_PROJECT=
# ADK_VERTEX_LOCATION=asia-south1

# ── Legacy single-model settings (only used when MODEL_ROUTER_ENABLED=false) ──
# In production these are ignored — agents declare ``model_tier`` and
# resolve via ModelRouter. Kept for explicit per-agent overrides + testing.
AGENT_MODEL_FAST=gemini-2.5-flash
AGENT_MODEL_QUALITY=gemini-2.5-pro

# Per-invocation hard caps (fail-safes, not optimization knobs).
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_COST_INR=10.0

# ── Model Router (multi-key + multi-model fallback) ──
# When true (default), agents resolve model_tier through ModelRouter backed
# by a litellm.Router. Set to false to bypass routing entirely — useful for
# narrow regression tests against a single model.
MODEL_ROUTER_ENABLED=true
# Seconds a deployment stays cooled-down after a 429 / capacity error.
# 60s matches Gemini's per-minute window; raise for daily-cap-heavy work.
MODEL_ROUTER_COOLDOWN_SECONDS=60
# usage-based-routing-v2 honors per-deployment RPM/TPM caps — required for
# free tier. Alternatives: simple-shuffle, least-busy, latency-based-routing.
MODEL_ROUTER_STRATEGY=usage-based-routing-v2

# ── Web Search (Phase 2) ──
# TAVILY_API_KEY=

# ── Auth (Phase 1 W3 wires Clerk; until then dev-mode) ──
AUTH_ENABLED=false
DEV_FIRM_ID=QUANTSOFT

# ── Catalog DB (READ-ONLY secondary connection) ──
# Points at the shared stock_chat Postgres — PRISM reads `company_industry`
# (4,773 companies) from here instead of duplicating a `companies` table.
# Strictly read-only (the BMC + stock-chat services own these tables).
# If unset, falls back to POSTGRES_URL (the teammate's env-var name).
CATALOG_DATABASE_URL=postgresql+asyncpg://stock_user:PASSWORD@35.234.221.166:5434/stock_chat

# ── Integrations (external services — no caller auth; network-restricted) ──
# stock-chat: filings catalog/lookup/read + technicals. Dev local, prod VM:8011.
STOCK_CHAT_URL=http://localhost:8011
# bmc: external BMC service (read-on-demand 9-block canvas, drill-down chat,
# JSON/PDF export, temporal diff). Replaces PRISM's prior RAG BMC entirely.
# Dev local, prod VM:8012. Firewall must allow this backend's IP on :8012.
BMC_URL=http://localhost:8012
