# ══════════════════════════════════════════════════════════════
# PRISM Analyst Services — Environment Variables
#
# DATABASE IS OPTIONAL. The backend runs with just these
# minimal settings. Add DB credentials when ready.
#
# Provider-agnostic: works with AWS RDS, GCP Cloud SQL,
# Supabase, Neon, Railway, or any PostgreSQL instance.
# ══════════════════════════════════════════════════════════════

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=["https://prism.thequantsoft.co.in"]

# ── Database (OPTIONAL — uncomment and fill when ready) ──
# Supports any PostgreSQL provider. Just change the host/credentials.
#
# AWS RDS:
#   DB_HOST=your-instance.rds.amazonaws.com
#   DB_SSL_MODE=verify-ca
#   DB_SSL_ROOT_CERT=/app/global-bundle.pem
#
# Supabase:
#   DB_HOST=db.your-project.supabase.co
#   DB_SSL_MODE=require
#
# Neon:
#   DB_HOST=ep-xxx.us-east-2.aws.neon.tech
#   DB_SSL_MODE=require
#
# Local:
#   DB_HOST=localhost
#   DB_SSL_MODE=disable
#
# DB_HOST=
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL_MODE=prefer
# DB_SSL_ROOT_CERT=

# ── LLM Keys (OPTIONAL — for Phase 2 agent integration) ──
# GEMINI_API_KEY=
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=
# OPENROUTER_API_KEY=

# ── Web Search (OPTIONAL — for Phase 2) ──
# TAVILY_API_KEY=

# ── Feature Flags ──
AUTH_ENABLED=false
