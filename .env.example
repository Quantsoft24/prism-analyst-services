# ══════════════════════════════════════════════════
# PRISM Analyst Services — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# ── Database (PostgreSQL — AWS RDS / Cloud SQL / Local) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_SSL_MODE=prefer
DB_SSL_ROOT_CERT=

# ── LLM: Gemini API Keys (round-robin fallback) ──
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# ── LLM: OpenRouter (fallback when Gemini is rate-limited) ──
OPENROUTER_API_KEY=

# ── Web Search ──
TAVILY_API_KEY=

# ── Feature Flags ──
AUTH_ENABLED=false
